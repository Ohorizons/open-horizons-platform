# =============================================================================
# OPEN HORIZONS PLATFORM — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The install wizard (scripts/install-wizard.sh) can generate this for you.
#
# Usage:
#   cp .env.example .env
#   $EDITOR .env
#   scripts/install-wizard.sh          # or configure manually
#   scripts/render-k8s.sh              # generate K8s manifests from templates
#   scripts/deploy-full.sh             # deploy to AKS
# =============================================================================

# -----------------------------------------------------------------------------
# 1. PLATFORM IDENTITY
# -----------------------------------------------------------------------------
# Your platform name (used in K8s labels, resource names, page title)
PLATFORM_NAME=openhorizons

# Your custom domain (leave empty for sslip.io auto-domain)
DOMAIN=

# Admin email for Let's Encrypt TLS certificates
ADMIN_EMAIL=admin@example.com

# Organization display name (shown in Backstage UI)
ORG_DISPLAY_NAME="My Organization"

# -----------------------------------------------------------------------------
# 2. GITHUB INTEGRATION
# -----------------------------------------------------------------------------
# GitHub organization or user that owns the forked repo
GITHUB_ORG=

# GitHub repository name (your fork)
GITHUB_REPO=ohorizons-demo

# GitHub Personal Access Token (scopes: repo, read:org, read:user)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# 3. AUTHENTICATION PROVIDER
# -----------------------------------------------------------------------------
# Options: github | entra | guest
AUTH_PROVIDER=github

# --- GitHub OAuth (required if AUTH_PROVIDER=github) ---
# Create at: https://github.com/settings/applications/new
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# --- Microsoft Entra ID (required if AUTH_PROVIDER=entra) ---
# Create at: https://portal.azure.com > App registrations
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# 4. CONTAINER REGISTRY
# -----------------------------------------------------------------------------
# Options: ghcr | acr | dockerhub
CONTAINER_REGISTRY=ghcr

# Pre-built public images (default — no registry setup needed)
BACKSTAGE_IMAGE=ghcr.io/ohorizons/ohorizons-backstage
AGENT_API_IMAGE=ghcr.io/ohorizons/ohorizons-agent-api
AGENT_API_IMPACT_IMAGE=ghcr.io/ohorizons/ohorizons-agent-api-impact
MCP_ECOSYSTEM_IMAGE=ghcr.io/ohorizons/mcp-ecosystem

# Image tag (default: latest stable)
IMAGE_TAG=v7.2.2

# --- Azure Container Registry (required if CONTAINER_REGISTRY=acr) ---
ACR_NAME=
# ACR_LOGIN_SERVER is auto-derived: ${ACR_NAME}.azurecr.io

# -----------------------------------------------------------------------------
# 5. AZURE INFRASTRUCTURE
# -----------------------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=eastus2
AKS_CLUSTER_NAME=

# -----------------------------------------------------------------------------
# 6. AI SERVICES (optional — needed for AI Chat & AI Impact plugins)
# -----------------------------------------------------------------------------
# Azure OpenAI endpoint (e.g., https://myopenai.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# -----------------------------------------------------------------------------
# 7. OBSERVABILITY (optional — auto-configured if enabled in wizard)
# -----------------------------------------------------------------------------
ARGOCD_AUTH_TOKEN=
GRAFANA_TOKEN=

# -----------------------------------------------------------------------------
# 8. BACKSTAGE BACKEND
# -----------------------------------------------------------------------------
# Random secret for Backstage backend auth (auto-generated if empty)
BACKEND_SECRET=
