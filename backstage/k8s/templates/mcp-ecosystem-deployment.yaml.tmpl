apiVersion: apps/v1
kind: Deployment
metadata:
  name: mcp-ecosystem
  namespace: ai-services
  labels:
    app.kubernetes.io/name: mcp-ecosystem
    app.kubernetes.io/part-of: __PLATFORM_NAME__
    horizon: h3
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: mcp-ecosystem
  template:
    metadata:
      labels:
        app.kubernetes.io/name: mcp-ecosystem
        app.kubernetes.io/part-of: __PLATFORM_NAME__
    spec:
      containers:
        - name: mcp-ecosystem
          image: __MCP_ECOSYSTEM_IMAGE__:__IMAGE_TAG__
          imagePullPolicy: Always
          ports:
            - containerPort: 3100
          env:
            - name: PORT
              value: "3100"
            - name: CACHE_DIR
              value: /app/cache
          resources:
            requests:
              cpu: 50m
              memory: 128Mi
            limits:
              cpu: 300m
              memory: 256Mi
          readinessProbe:
            httpGet:
              path: /health
              port: 3100
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /health
              port: 3100
            initialDelaySeconds: 10
            periodSeconds: 30
---
apiVersion: v1
kind: Service
metadata:
  name: mcp-ecosystem
  namespace: ai-services
  labels:
    app.kubernetes.io/name: mcp-ecosystem
    app.kubernetes.io/part-of: __PLATFORM_NAME__
spec:
  type: ClusterIP
  ports:
    - port: 3100
      targetPort: 3100
      protocol: TCP
      name: http
  selector:
    app.kubernetes.io/name: mcp-ecosystem
