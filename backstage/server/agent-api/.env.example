# ──────────────────────────────────────────────
# Open Horizons — AI Chat Agent (Azure OpenAI)
# ──────────────────────────────────────────────

# Required: Azure OpenAI endpoint and API key
AZURE_OPENAI_ENDPOINT=https://ohorizons-ai-foundry.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Deployment name (default: gpt-5-1)
AZURE_OPENAI_DEPLOYMENT=gpt-5-1

# Model display name for health/info endpoints
MODEL_DISPLAY_NAME=gpt-5.1

# Max tokens per response
MAX_TOKENS=4096

# Server config
HOST=0.0.0.0
PORT=8008

# CORS — Backstage frontend origin
CORS_ORIGINS=http://localhost:3000,http://localhost:7007

# Optional: MCP server endpoint for Backstage catalog tools
MCP_ENDPOINT=http://localhost:7007/api/mcp-actions/v1

# Optional: logging level
LOG_LEVEL=INFO
