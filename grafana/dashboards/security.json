{
  "__comment": "OPEN HORIZONS PLATFORM - SECURITY DASHBOARD",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["open-horizons"],
      "targetBlank": true,
      "title": "Platform Dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Gatekeeper Policy Enforcement",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "title": "Policy Violations (24h)",
      "description": "Total Gatekeeper constraint violations in the last 24 hours",
      "targets": [
        {
          "expr": "sum(increase(gatekeeper_violations[24h])) or vector(0)",
          "legendFormat": "Violations"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "title": "Active Constraints",
      "description": "Number of Gatekeeper constraints enforced",
      "targets": [
        {
          "expr": "count(gatekeeper_constraints) or vector(0)",
          "legendFormat": "Constraints"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 3 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "title": "Constraint Templates",
      "description": "Number of Gatekeeper constraint templates deployed",
      "targets": [
        {
          "expr": "count(gatekeeper_constraint_templates) or vector(0)",
          "legendFormat": "Templates"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "title": "Admission Webhook Success Rate",
      "description": "Percentage of successful admission webhook calls",
      "targets": [
        {
          "expr": "100 * (1 - sum(rate(gatekeeper_webhook_request_total{status=\"error\"}[5m])) / sum(rate(gatekeeper_webhook_request_total[5m])))",
          "legendFormat": "Success %"
        }
      ],
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Workload Security Posture",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "title": "Gatekeeper Violations Over Time",
      "description": "Policy violations trend by constraint kind",
      "targets": [
        {
          "expr": "sum(increase(gatekeeper_violations[1h])) by (constraint_kind)",
          "legendFormat": "{{ constraint_kind }}"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "title": "Admission Webhook Latency",
      "description": "Gatekeeper webhook response time",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gatekeeper_webhook_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gatekeeper_webhook_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gatekeeper_webhook_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Container Security",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 15 },
      "id": 7,
      "title": "Privileged Containers",
      "description": "Number of containers running with privileged mode (should be 0)",
      "targets": [
        {
          "expr": "count(kube_pod_container_info{namespace!~\"kube-system|gatekeeper-system\"} and on(pod, namespace) kube_pod_spec_containers_security_context_privileged{value=\"true\"}) or vector(0)",
          "legendFormat": "Privileged"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 15 },
      "id": 8,
      "title": "Root Containers",
      "description": "Number of containers running as root (should be 0 outside kube-system)",
      "targets": [
        {
          "expr": "count(kube_pod_container_info{namespace!~\"kube-system|gatekeeper-system|observability\"} and on(pod, namespace) kube_pod_spec_containers_security_context_run_as_non_root{value=\"false\"}) or vector(0)",
          "legendFormat": "Root"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 15 },
      "id": 9,
      "title": "Images from Approved Registries",
      "description": "Percentage of container images from approved registries",
      "targets": [
        {
          "expr": "100 * count(kube_pod_container_info{image=~\"(acr.*azurecr\\.io|mcr\\.microsoft\\.com|ghcr\\.io|registry\\.k8s\\.io)/.*\"}) / count(kube_pod_container_info) or vector(100)",
          "legendFormat": "Approved %"
        }
      ],
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 103,
      "title": "Network and TLS",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 10,
      "title": "TLS Certificate Expiry",
      "description": "Days until TLS certificate expiration per ingress",
      "targets": [
        {
          "expr": "(certmanager_certificate_expiration_timestamp_seconds - time()) / 86400",
          "legendFormat": "{{ name }} ({{ namespace }})"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 11,
      "title": "Network Policy Coverage",
      "description": "Namespaces with network policies vs. total namespaces",
      "targets": [
        {
          "expr": "count(kube_networkpolicy_labels)",
          "legendFormat": "Network Policies"
        },
        {
          "expr": "count(kube_namespace_labels{namespace!~\"kube-.*|default\"})",
          "legendFormat": "Active Namespaces"
        }
      ],
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["open-horizons", "security", "compliance"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Open Horizons - Security",
  "uid": "oh-security",
  "version": 1
}
